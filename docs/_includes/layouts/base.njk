{% import "components/ui.njk" as ui %}
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} | {% endif %}{{ site.name }}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="icon" href="/assets/images/logos/logo.png" />
    <link rel="stylesheet" href="/assets/app.css" />
    <link rel="stylesheet" href="/assets/site.css" />
  </head>
  <body class="bg-background text-brand-ink-900">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-full focus:bg-white focus:px-4 focus:py-2 focus:shadow-card">Saltar al contenido</a>

    <nav class="fixed left-0 right-0 top-0 z-50 bg-white/90 shadow-soft backdrop-blur-sm">
      <div class="container mx-auto px-4 sm:px-6">
        <div class="flex h-16 items-center justify-between sm:h-20">
          <a href="/" class="group flex items-center">
            <div class="scale-100 transition-smooth">
              <img src="/assets/images/logos/logo.png" alt="Fin de la Esclavitud" class="h-14 w-auto object-contain transition-transform duration-300 group-hover:scale-105 sm:h-16" />
            </div>
          </a>

          <div class="hidden items-center gap-1 lg:flex">
            {% for item in site.nav %}
              {% set isCurrent = (page.url | isCurrentPath(item.href)) or (item.label == "Aprende" and page.url.startsWith("/aprende/")) %}
              {% if item.submenu %}
                <div class="group relative">
                  <button
                    type="button"
                    class="relative flex items-center gap-1 rounded-lg px-3 py-2 font-body text-sm font-medium transition-smooth xl:px-4 {% if isCurrent %}text-brand-teal-500{% else %}text-brand-ink-800 hover:text-brand-teal-500{% endif %}"
                    aria-haspopup="true"
                  >
                    {{ item.label }}
                    {{ ui.icon("chevron-down", "h-4 w-4 transition-transform duration-300 group-hover:rotate-180") }}
                    <span class="absolute bottom-0 left-0 h-0.5 w-full origin-left bg-gradient-to-r from-brand-teal-500 to-brand-mint-200 transition-smooth {% if isCurrent %}scale-x-100{% else %}scale-x-0 group-hover:scale-x-100{% endif %}"></span>
                  </button>
                  <div class="pointer-events-none invisible absolute left-0 top-full mt-2 min-w-[260px] rounded-2xl border border-brand-teal-500/10 bg-white/95 p-3 opacity-0 shadow-card transition-all duration-300 group-hover:pointer-events-auto group-hover:visible group-hover:opacity-100">
                    {% for subitem in item.submenu %}
                      <a href="{{ subitem.href }}" class="block rounded-xl px-4 py-3 font-body text-sm text-brand-ink-700 transition-smooth hover:bg-brand-mint-200/30 hover:text-brand-teal-500">
                        {{ subitem.label }}
                      </a>
                    {% endfor %}
                  </div>
                </div>
              {% else %}
                <a
                  href="{{ item.href }}"
                  class="group relative rounded-lg px-3 py-2 font-body text-sm font-medium transition-smooth xl:px-4 {% if isCurrent %}text-brand-teal-500{% else %}text-brand-ink-800 hover:text-brand-teal-500{% endif %}"
                >
                  {{ item.label }}
                  <span class="absolute bottom-0 left-0 h-0.5 w-full origin-left bg-gradient-to-r from-brand-teal-500 to-brand-mint-200 transition-smooth {% if isCurrent %}scale-x-100{% else %}scale-x-0 group-hover:scale-x-100{% endif %}"></span>
                </a>
              {% endif %}
            {% endfor %}
          </div>

          <div class="hidden items-center gap-3 lg:flex">
            {% if site.ctas[0] %}
              <a href="{{ site.ctas[0].href }}" {% if site.ctas[0].external %}target="_blank" rel="noopener noreferrer"{% endif %} class="inline-flex h-9 items-center justify-center gap-2 rounded-md border border-brand-ink-800/10 bg-white px-3 font-body text-sm font-medium text-brand-ink-900 shadow-soft transition-smooth hover:bg-brand-mint-200/20 hover:shadow-cta">
                {{ ui.icon("house", "h-4 w-4") }}
                <span>{{ site.ctas[0].label }}</span>
              </a>
            {% endif %}
            {% if site.ctas[1] %}
              <a href="{{ site.ctas[1].href }}" {% if site.ctas[1].external %}target="_blank" rel="noopener noreferrer"{% endif %} class="inline-flex h-9 items-center justify-center gap-2 rounded-md bg-brand-ink-800 px-3 font-heading text-sm font-semibold text-white shadow-soft transition-smooth hover:bg-brand-ink-900 hover:shadow-cta">
                {{ ui.icon("heart", "h-4 w-4") }}
                <span>{{ site.ctas[1].label }}</span>
              </a>
            {% endif %}
          </div>

          <div class="flex items-center gap-2 lg:hidden">
            {% if site.ctas[0] %}
              <a href="{{ site.ctas[0].href }}" {% if site.ctas[0].external %}target="_blank" rel="noopener noreferrer"{% endif %} class="inline-flex h-9 w-9 items-center justify-center rounded-md px-3 text-brand-teal-500 transition-smooth hover:bg-brand-teal-500/10 hover:text-brand-teal-500" aria-label="{{ site.ctas[0].label }}">
                {{ ui.icon("house", "h-5 w-5") }}
              </a>
            {% endif %}
            {% if site.ctas[1] %}
              <a href="{{ site.ctas[1].href }}" {% if site.ctas[1].external %}target="_blank" rel="noopener noreferrer"{% endif %} class="inline-flex h-9 w-9 items-center justify-center rounded-md px-3 text-brand-teal-500 transition-smooth hover:bg-brand-teal-500/10 hover:text-brand-teal-500" aria-label="{{ site.ctas[1].label }}">
                {{ ui.icon("heart", "h-5 w-5") }}
              </a>
            {% endif %}
            <button id="mobile-nav-toggle" class="inline-flex h-10 w-10 items-center justify-center rounded-md text-brand-ink-900 transition-smooth hover:bg-brand-teal-500/10 hover:text-brand-teal-500" aria-expanded="false" aria-controls="mobile-nav">
              <span class="sr-only">Abrir navegación</span>
              <span data-icon="menu">{{ ui.icon("menu", "h-6 w-6") }}</span>
              <span data-icon="close" class="hidden">{{ ui.icon("close", "h-6 w-6") }}</span>
            </button>
          </div>
        </div>

        <div id="mobile-nav" class="mobile-nav lg:hidden">
          <div class="flex flex-col gap-1 pt-2">
            {% for item in site.nav %}
              {% set isCurrent = (page.url | isCurrentPath(item.href)) or (item.label == "Aprende" and page.url.startsWith("/aprende/")) %}
              {% if item.submenu %}
                <div class="mobile-submenu{% if isCurrent %} is-open{% endif %}" data-mobile-submenu>
                  <button type="button" class="mobile-submenu-toggle w-full rounded-lg px-4 py-3 text-left font-body text-sm font-medium text-brand-ink-800 transition-smooth hover:bg-brand-mint-200/30 hover:text-brand-teal-500" data-mobile-submenu-toggle aria-expanded="{% if isCurrent %}true{% else %}false{% endif %}">
                    <div class="flex items-center justify-between">
                      <span>{{ item.label }}</span>
                      {{ ui.icon("chevron-down", "h-4 w-4 transition-transform duration-300") }}
                    </div>
                  </button>
                  <div class="mobile-submenu-panel" data-mobile-submenu-panel>
                    <div class="mt-1 space-y-1 pl-3">
                      {% for subitem in item.submenu %}
                        {% set isSubCurrent = page.url | isCurrentPath(subitem.href) %}
                        <a href="{{ subitem.href }}" class="block rounded-lg px-4 py-2.5 font-body text-sm transition-smooth {% if isSubCurrent %}bg-brand-teal-500/10 text-brand-teal-500{% else %}text-brand-ink-700 hover:bg-brand-mint-200/20 hover:text-brand-teal-500{% endif %}">
                          <div class="flex items-center justify-between">
                            <span>{{ subitem.label }}</span>
                            {% if isSubCurrent %}
                              <span class="h-2 w-2 rounded-full bg-brand-teal-500"></span>
                            {% endif %}
                          </div>
                        </a>
                      {% endfor %}
                    </div>
                  </div>
                </div>
              {% else %}
                <a href="{{ item.href }}" class="relative rounded-lg px-4 py-3 font-body text-sm font-medium transition-smooth {% if isCurrent %}bg-brand-teal-500/10 text-brand-teal-500{% else %}text-brand-ink-800 hover:bg-brand-mint-200/30 hover:text-brand-teal-500{% endif %}">
                  <div class="flex items-center justify-between">
                    <span>{{ item.label }}</span>
                    {% if isCurrent %}
                      <span class="h-2 w-2 rounded-full bg-brand-teal-500"></span>
                    {% endif %}
                  </div>
                </a>
              {% endif %}
            {% endfor %}

            <div class="my-2 h-px bg-brand-mint-200/30"></div>

            {% if site.ctas[0] %}
              <a href="{{ site.ctas[0].href }}" {% if site.ctas[0].external %}target="_blank" rel="noopener noreferrer"{% endif %} class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-brand-teal-500 bg-white px-4 py-3 font-body text-sm font-semibold text-brand-teal-500 transition-smooth hover:bg-brand-teal-500/10">
                {{ ui.icon("house", "h-4 w-4") }}
                <span>{{ site.ctas[0].label }}</span>
              </a>
            {% endif %}
            {% if site.ctas[1] %}
              <a href="{{ site.ctas[1].href }}" {% if site.ctas[1].external %}target="_blank" rel="noopener noreferrer"{% endif %} class="inline-flex items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-brand-teal-500 to-brand-ink-800 px-4 py-3 font-body text-sm font-semibold text-white transition-smooth hover:shadow-cta">
                {{ ui.icon("heart", "h-4 w-4") }}
                <span>Hacer una Donación</span>
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    </nav>

    <main id="main-content">
      {{ content | safe }}
    </main>

    {% if not noFooter %}
      <footer class="relative overflow-hidden bg-gradient-to-br from-brand-ink-900 via-brand-ink-800 to-brand-ink-900 text-white">
        <div class="absolute inset-0 overflow-hidden pointer-events-none">
          <div class="absolute left-10 top-10 h-32 w-32 rounded-full bg-brand-teal-500/5 blur-3xl"></div>
          <div class="absolute bottom-10 right-10 h-40 w-40 rounded-full bg-brand-mint-200/5 blur-3xl"></div>
        </div>

        <div class="relative container mx-auto px-4 sm:px-6">
          <div class="grid gap-8 py-12 sm:grid-cols-2 sm:gap-10 sm:py-16 lg:grid-cols-4 lg:gap-12">
            <div>
              <a href="/" class="mb-4 flex items-center gap-3">
                <img src="/assets/images/logos/logo.png" alt="Fin de la Esclavitud" class="h-12 w-12 object-contain brightness-0 invert" />
                <h2 class="font-heading text-xl font-bold text-white">Fin de la Esclavitud</h2>
              </a>
              <p class="font-body text-sm leading-relaxed text-white/70">{{ site.description }}</p>

              <div class="mt-6 flex gap-3">
                {% for social in site.social %}
                  <a href="{{ social.href }}" target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-full border border-white/20 bg-white/10 transition-smooth hover:bg-brand-teal-500" aria-label="{{ social.label }}">
                    {{ ui.icon(social.icon, "h-5 w-5 text-white/80") }}
                  </a>
                {% endfor %}
              </div>
            </div>

            <div>
              <h3 class="mb-4 flex items-center gap-2 font-heading text-base font-semibold text-white">
                <span class="h-4 w-1 rounded-full bg-brand-teal-500"></span>
                Enlaces Rápidos
              </h3>
              <ul class="space-y-3">
                {% for link in site.quickLinks %}
                  <li><a href="{{ link.href }}" class="font-body text-sm text-white/70 transition-smooth hover:text-brand-mint-200">{{ link.label }}</a></li>
                {% endfor %}
              </ul>
            </div>

            <div>
              <h3 class="mb-4 flex items-center gap-2 font-heading text-base font-semibold text-white">
                <span class="h-4 w-1 rounded-full bg-brand-mint-200"></span>
                Recursos
              </h3>
              <ul class="space-y-3">
                {% for link in site.resourceLinks %}
                  <li><a href="{{ link.href }}" class="font-body text-sm text-white/70 transition-smooth hover:text-brand-mint-200">{{ link.label }}</a></li>
                {% endfor %}
              </ul>
            </div>

            <div>
              <h3 class="mb-4 flex items-center gap-2 font-heading text-base font-semibold text-white">
                <span class="h-4 w-1 rounded-full bg-brand-olive-500"></span>
                Contacto
              </h3>
              <ul class="space-y-3">
                {% for item in site.contact %}
                  <li>
                    <a href="{{ item.href }}" class="inline-flex items-start gap-3 font-body text-sm text-white/70 transition-smooth hover:text-brand-mint-200">
                      {{ ui.icon(item.icon, "mt-0.5 h-4 w-4 flex-shrink-0") }}
                      <span>{{ item.label }}</span>
                    </a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          </div>

          <div class="border-t border-white/10 py-6">
            <p class="text-center font-body text-sm text-white/60">© {{ "" | year }} {{ site.name }}. Todos los derechos reservados.</p>
          </div>
        </div>
      </footer>
    {% endif %}

    <script src="/assets/site.js" defer></script>
  </body>
</html>
