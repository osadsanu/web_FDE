---
layout: layouts/base.njk
---
{% import "components/ui.njk" as ui %}

<div class="min-h-screen bg-gradient-subtle">
  <main class="relative pb-20 pt-28 sm:pt-32">
    <section class="relative mx-4 mb-12 overflow-hidden rounded-2xl shadow-card sm:mx-6 lg:mx-12">
      <img src="{{ hero_image }}" alt="{{ hero_image_alt }}" class="h-80 w-full object-cover sm:h-96 md:h-[500px] lg:h-[600px]" />
      <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-brand-ink-900/90 via-brand-teal-500/80 to-brand-ink-800/90 p-4">
        <div class="max-w-4xl text-center text-white">
          <div class="mb-6 flex justify-center">
            <div class="rounded-full bg-white/10 p-4 backdrop-blur-sm">
              {{ ui.icon(hero_icon, "h-12 w-12 text-brand-mint-200") }}
            </div>
          </div>
          <blockquote class="mb-6 font-heading text-2xl italic text-brand-mint-200 sm:text-3xl">“{{ quote.text }}”</blockquote>
          <p class="mb-6 font-body text-base uppercase tracking-[0.2em] text-white/75">{{ quote.author }}</p>
          <h1 class="mb-4 font-heading text-4xl font-bold sm:text-5xl lg:text-6xl">{{ hero_title }}</h1>
          <p class="font-body text-lg leading-relaxed text-white/85 sm:text-xl">{{ hero_subtitle }}</p>
        </div>
      </div>
    </section>

    <div class="container mx-auto px-4 sm:px-6">
      <section class="grid gap-8 lg:grid-cols-2 xl:grid-cols-4">
        {% for action in actions %}
          <article class="group icon-hover-card rounded-3xl border border-brand-teal-500/10 bg-white p-8 shadow-card">
            <div class="icon-hover-glow bg-brand-teal-500/10"></div>
            <div class="icon-hover-shell mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-teal-500 to-brand-ink-800 shadow-soft">
              {{ ui.icon(action.icon, "h-8 w-8 text-white") }}
            </div>
            <h2 class="mb-4 font-heading text-2xl font-bold text-brand-ink-900">{{ action.title }}</h2>
            <p class="mb-6 font-body text-base leading-relaxed text-brand-ink-700">{{ action.description }}</p>
            <ul class="space-y-3">
              {% for step in action.steps %}
                <li class="inline-flex items-center gap-3 font-body text-sm text-brand-ink-800">
                  <span class="h-2 w-2 rounded-full bg-brand-teal-500"></span>
                  {{ step }}
                </li>
              {% endfor %}
            </ul>
          </article>
        {% endfor %}
      </section>

      <section class="mt-16 sm:mt-20">
        <div class="mb-8 text-center">
          <h2 class="mb-4 font-heading text-3xl font-bold text-brand-ink-900 sm:text-4xl">{{ benefits_title }}</h2>
          <p class="font-body text-base text-brand-ink-700 sm:text-lg">{{ benefits_subtitle }}</p>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {% for benefit in benefits %}
            <article class="rounded-3xl bg-gradient-to-br from-brand-ink-900 via-brand-teal-700 to-brand-ink-800 p-8 text-center shadow-cta">
              <h3 class="mb-4 font-heading text-2xl font-bold text-white">{{ benefit.title }}</h3>
              <p class="font-body text-base leading-relaxed text-white/85">{{ benefit.description }}</p>
            </article>
          {% endfor %}
        </div>
      </section>
    </div>
  </main>
</div>
