---
layout: layouts/base.njk
---
{% import "components/ui.njk" as ui %}

<section id="inicio" class="relative flex min-h-screen items-center justify-center overflow-hidden" data-home-section="hero">
  <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('{{ hero_image }}')">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-ink-900/80 via-brand-teal-500/70 to-brand-ink-800/80"></div>
    <div class="absolute left-10 top-20 h-32 w-32 rounded-full bg-brand-mint-200/10 blur-3xl animate-float"></div>
    <div class="absolute bottom-20 right-10 h-40 w-40 rounded-full bg-brand-teal-500/10 blur-3xl animate-float delay-1000"></div>
  </div>

  <div class="hero-slider relative z-10 w-full" data-hero-slider>
    {% for slide in hero_slides %}
      <div class="hero-slide relative z-10 px-4 py-20 text-center text-white transition-opacity duration-300 sm:px-6 {% if loop.first %}is-active{% endif %}" data-hero-slide>
        <div class="mx-auto max-w-6xl">
          <div class="mb-6 flex justify-center sm:mb-8"></div>
          <h1 class="mb-6 font-heading font-bold tracking-tight sm:mb-8" style="line-height: var(--lh-heading-1);" data-hero-heading>
            <span class="mb-2 block text-3xl text-brand-mint-200 animate-slide-up sm:mb-3 sm:text-4xl md:text-5xl lg:text-6xl">{{ slide.title }}</span>
            <span class="mb-2 block text-4xl animate-slide-up sm:mb-3 sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl">{{ slide.subtitle }}</span>
            <span class="block text-4xl animate-slide-up sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl">{{ slide.quote }}</span>
          </h1>

          <div class="mb-10 flex items-center justify-center gap-3 animate-fade-in sm:mb-12 sm:gap-4" data-hero-author>
            <div class="h-px w-12 bg-brand-mint-200/50 sm:w-16"></div>
            <p class="font-body text-base font-medium italic text-brand-mint-200/90 sm:text-lg md:text-xl lg:text-2xl">{{ slide.author }}</p>
            <div class="h-px w-12 bg-brand-mint-200/50 sm:w-16"></div>
          </div>

          <div class="flex flex-col items-center justify-center gap-4 animate-fade-in sm:flex-row" data-hero-actions>
            <a href="{{ primary_cta.href }}" {% if primary_cta.external %}target="_blank" rel="noopener noreferrer"{% endif %} class="group inline-flex w-full items-center justify-center rounded-xl bg-white px-6 py-6 font-body text-base font-bold text-brand-ink-900 shadow-cta transition-smooth hover:bg-brand-mint-200 hover:shadow-soft sm:w-auto sm:px-8 sm:text-lg" data-hero-action>
              {{ primary_cta.label }}
              {{ ui.icon("arrow-right", "ml-2 h-5 w-5 group-hover:translate-x-1 transition-smooth") }}
            </a>
            <a href="{{ secondary_cta.href }}" {% if secondary_cta.external %}target="_blank" rel="noopener noreferrer"{% endif %} class="inline-flex w-full items-center justify-center rounded-xl border border-white/30 bg-white/10 px-6 py-6 font-body text-base font-semibold text-white backdrop-blur-sm transition-smooth hover:bg-white/20 sm:w-auto sm:px-8 sm:text-lg" data-hero-action>
              {{ secondary_cta.label }}
            </a>
          </div>
        </div>
      </div>
    {% endfor %}

    <button type="button" class="absolute left-2 top-1/2 z-20 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full border border-white/30 bg-white/5 text-white backdrop-blur-sm transition-smooth hover:bg-white/20 sm:left-4 sm:h-12 sm:w-12 md:left-8" aria-label="Slide anterior" data-hero-prev data-hero-arrow>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-8 sm:w-8"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button type="button" class="absolute right-2 top-1/2 z-20 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full border border-white/30 bg-white/5 text-white backdrop-blur-sm transition-smooth hover:bg-white/20 sm:right-4 sm:h-12 sm:w-12 md:right-8" aria-label="Slide siguiente" data-hero-next data-hero-arrow>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-8 sm:w-8"><path d="m9 18 6-6-6-6"/></svg>
    </button>

    <div class="absolute bottom-6 left-1/2 z-20 flex -translate-x-1/2 gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 backdrop-blur-sm sm:bottom-8 sm:gap-3" data-hero-dots>
      {% for slide in hero_slides %}
        <button type="button" class="hero-dot rounded-full transition-all {% if loop.first %}bg-white h-2 w-8 sm:h-3 sm:w-10{% else %}bg-white/50 h-2 w-2 hover:bg-white/70 sm:h-3 sm:w-3{% endif %}" aria-label="Ir a slide {{ loop.index }}" data-hero-dot data-index="{{ loop.index0 }}"></button>
      {% endfor %}
    </div>
  </div>
</section>

<section class="relative overflow-hidden py-20 sm:py-24 lg:py-32" data-home-section="purpose">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-ink-900 via-brand-teal-600 to-brand-ink-800">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-40"></div>
  </div>
  <div class="absolute left-10 top-20 h-40 w-40 rounded-full bg-brand-mint-200/10 blur-3xl animate-float"></div>
  <div class="absolute bottom-20 right-10 h-48 w-48 rounded-full bg-brand-teal-500/10 blur-3xl animate-float delay-1000"></div>
  <div class="absolute left-1/3 top-1/2 h-32 w-32 rounded-full bg-white/5 blur-2xl animate-float delay-500"></div>

  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center animate-fade-in sm:mb-20">
      <div class="mb-6 inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-6 py-3 backdrop-blur-sm">
        <span class="font-body text-sm font-semibold uppercase tracking-widest text-brand-mint-200">{{ purpose.eyebrow }}</span>
      </div>
      <h2 class="mb-6 font-heading text-4xl font-bold leading-tight text-white sm:text-5xl lg:text-6xl xl:text-7xl">
        FIN DE LA <span class="text-brand-mint-200">ESCLAVITUD</span>
      </h2>
      <div class="mx-auto max-w-4xl">
        <p class="font-body text-lg leading-relaxed text-white/90 sm:text-xl lg:text-2xl">{{ purpose.intro }}</p>
      </div>
    </div>

    <div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-2 lg:gap-12">
      {% for card in purpose.cards %}
        <div class="group animate-fade-in {% if loop.index == 1 %}delay-150{% else %}delay-300{% endif %}">
          <article class="relative h-full overflow-hidden border-0 bg-white/95 p-8 shadow-cta transition-smooth hover:shadow-[0_20px_60px_-10px_rgba(0,0,0,0.3)] sm:p-10 lg:p-12 rounded-lg">
            <div class="absolute left-0 right-0 top-0 h-2 bg-gradient-to-r {% if loop.index == 1 %}from-brand-teal-500 via-brand-teal-400 to-brand-teal-500{% else %}from-brand-ink-800 via-brand-ink-700 to-brand-ink-800{% endif %}"></div>
            <div class="absolute right-0 top-0 h-32 w-32 rounded-full {% if loop.index == 1 %}bg-brand-teal-500/5{% else %}bg-brand-ink-800/5{% endif %} blur-2xl transition-smooth duration-500 group-hover:scale-150"></div>
            <div class="relative z-10">
              <div class="mb-6">
                <div class="inline-flex rounded-2xl bg-gradient-to-br {{ card.gradient }} p-4 shadow-soft transition-smooth group-hover:scale-110 group-hover:rotate-3">
                  {{ ui.icon(card.icon, "h-10 w-10 text-white") }}
                </div>
              </div>
              <h3 class="mb-6 font-heading text-3xl font-bold leading-tight text-brand-ink-900 sm:text-4xl">
                NUESTRA<br />
                <span class="{{ card.text_color }}">{{ card.title | replace('NUESTRA ', '') }}</span>
              </h3>
              <p class="font-body text-base leading-relaxed text-brand-ink-700 sm:text-lg">{{ card.text }}</p>
            </div>
          </article>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="relative overflow-hidden bg-white py-20 sm:py-24 lg:py-32" data-home-section="strategy">
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-mint-200/20 via-white to-brand-teal-500/10"></div>
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-60"></div>
  </div>
  <div class="absolute right-10 top-20 h-72 w-72 rounded-full bg-brand-teal-500/10 blur-3xl animate-float"></div>
  <div class="absolute bottom-20 left-10 h-80 w-80 rounded-full bg-brand-mint-200/30 blur-3xl animate-float delay-1000"></div>
  <div class="absolute left-1/2 top-1/2 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand-olive-500/5 blur-3xl animate-float delay-500"></div>

  <div class="relative container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center animate-fade-in sm:mb-20 lg:mb-24">
      <div class="mb-6 inline-flex items-center justify-center rounded-full border border-brand-teal-500/20 bg-gradient-to-r from-brand-teal-500/10 to-brand-mint-200/20 px-6 py-3 shadow-soft backdrop-blur-sm">
        <span class="font-body text-sm font-bold uppercase tracking-widest text-brand-teal-600">{{ strategy.eyebrow }}</span>
      </div>
      <h2 class="mb-6 font-heading text-4xl font-bold leading-tight text-brand-ink-900 sm:text-5xl lg:text-6xl xl:text-7xl">
        ¿Cómo lo <span class="text-brand-teal-600">logramos</span>?
      </h2>
      <p class="mx-auto max-w-3xl font-body text-lg leading-relaxed text-brand-ink-700 sm:text-xl lg:text-2xl">{{ strategy.subtitle }}</p>
      <div class="mt-8 flex items-center justify-center gap-3">
        <div class="h-1 w-20 rounded-full bg-gradient-to-r from-transparent to-brand-teal-500"></div>
        {{ ui.icon("target", "h-8 w-8 text-brand-teal-500") }}
        <div class="h-1 w-20 rounded-full bg-gradient-to-l from-transparent to-brand-teal-500"></div>
      </div>
    </div>

    <div class="mx-auto max-w-7xl space-y-12 sm:space-y-16 lg:space-y-20">
      {% for item in strategy.items %}
        {% set palettes = [
          { "gradient": "from-brand-teal-500 to-brand-teal-600", "light": "bg-brand-teal-500/5", "border": "border-brand-teal-500/20", "text": "text-brand-teal-600", "glow": "shadow-[0_0_40px_rgba(10,184,184,0.2)]" },
          { "gradient": "from-brand-ink-800 to-brand-ink-900", "light": "bg-brand-ink-800/5", "border": "border-brand-ink-800/20", "text": "text-brand-ink-800", "glow": "shadow-[0_0_40px_rgba(31,41,55,0.15)]" },
          { "gradient": "from-brand-olive-500 to-brand-olive-600", "light": "bg-brand-olive-500/5", "border": "border-brand-olive-500/20", "text": "text-brand-olive-600", "glow": "shadow-[0_0_40px_rgba(161,182,143,0.2)]" }
        ] %}
        {% set palette = palettes[loop.index0 % 3] %}
        <div class="group animate-fade-in {% if loop.index0 % 2 == 0 %}lg:pr-12{% else %}lg:pl-12{% endif %}" style="animation-delay: {{ loop.index0 * 150 }}ms;">
          <div class="flex flex-col items-center gap-8 {% if loop.index0 % 2 == 0 %}lg:flex-row{% else %}lg:flex-row-reverse{% endif %} lg:gap-12">
            <div class="relative flex-shrink-0">
              <div class="pointer-events-none absolute -top-8 select-none font-heading text-[120px] font-black {{ palette.text }} opacity-5 sm:text-[140px] {% if loop.index0 % 2 == 0 %}-left-8{% else %}-right-8{% endif %}">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</div>
              <div class="relative">
                <div class="absolute inset-0 rounded-full bg-gradient-to-br {{ palette.gradient }} opacity-20 blur-2xl transition-smooth group-hover:scale-175 scale-150"></div>
                <div class="relative flex h-32 w-32 items-center justify-center rounded-3xl bg-gradient-to-br {{ palette.gradient }} shadow-cta {{ palette.glow }} transition-smooth group-hover:scale-110 group-hover:rotate-3 sm:h-40 sm:w-40">
                  {{ ui.icon(item.icon, "h-16 w-16 text-white sm:h-20 sm:w-20") }}
                  <div class="absolute -right-3 -top-3 flex h-12 w-12 items-center justify-center rounded-full border-4 border-white bg-white shadow-soft">
                    <span class="font-heading text-lg font-bold {{ palette.text }}">{{ loop.index }}</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="flex-1 text-center lg:text-left">
              <div class="relative rounded-3xl border-2 {{ palette.border }} {{ palette.light }} p-8 shadow-card transition-smooth group-hover:shadow-cta sm:p-10">
                <div class="absolute top-0 {% if loop.index0 % 2 == 0 %}left-0{% else %}right-0{% endif %} h-1 w-24 rounded-full bg-gradient-to-r {{ palette.gradient }}"></div>
                <h3 class="mb-4 font-heading text-2xl font-bold {{ palette.text }} sm:text-3xl">{{ item.title }}</h3>
                <p class="font-body text-base leading-relaxed text-brand-ink-700 sm:text-lg">{{ item.text }}</p>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="relative overflow-hidden bg-gradient-to-br from-brand-ink-900 via-brand-teal-700 to-brand-ink-800 py-20 sm:py-24 lg:py-32" data-home-section="values">
  <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-40"></div>
  <div class="absolute left-10 top-10 h-64 w-64 rounded-full bg-brand-mint-200/10 blur-3xl animate-float"></div>
  <div class="absolute bottom-10 right-10 h-80 w-80 rounded-full bg-brand-teal-400/10 blur-3xl animate-float delay-1000"></div>

  <div class="relative container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center animate-fade-in sm:mb-20">
      <div class="mb-6 inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-6 py-3 shadow-soft backdrop-blur-sm">
        <span class="font-body text-sm font-bold uppercase tracking-widest text-brand-mint-200">{{ values.eyebrow }}</span>
      </div>
      <h2 class="mb-6 font-heading text-4xl font-bold leading-tight text-white sm:text-5xl lg:text-6xl xl:text-7xl">
        NUESTROS <span class="text-brand-mint-200">VALORES</span>
      </h2>
      <p class="mx-auto max-w-3xl font-body text-lg leading-relaxed text-white/90 sm:text-xl">{{ values.subtitle }}</p>
    </div>

    <div class="grid max-w-7xl justify-items-center gap-6 sm:grid-cols-2 lg:grid-cols-4 sm:gap-8 mx-auto">
      {% for item in values.items %}
        <article class="group animate-fade-in h-full w-full max-w-sm" style="animation-delay: {{ loop.index0 * 100 }}ms;">
          <div class="relative h-full">
            <div class="relative flex h-full flex-col items-center rounded-3xl border-2 border-white/50 bg-white/95 p-8 shadow-cta transition-smooth hover:shadow-[0_20px_60px_-10px_rgba(0,0,0,0.4)]">
              <div class="absolute left-0 right-0 top-0 h-1.5 rounded-t-3xl bg-gradient-to-r {{ item.gradient }}"></div>
              <div class="absolute -right-8 -top-8 h-32 w-32 rounded-full {% if loop.index0 % 3 == 0 %}bg-brand-teal-500/10{% elseif loop.index0 % 3 == 1 %}bg-brand-ink-800/10{% else %}bg-brand-olive-500/10{% endif %} blur-2xl transition-smooth duration-500 group-hover:scale-150"></div>
              <div class="relative z-10 flex w-full flex-col items-center">
                <div class="mb-6">
                  <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-gradient-to-br {{ item.gradient }} shadow-soft transition-smooth group-hover:scale-110 group-hover:rotate-6">
                    {{ ui.icon(item.icon, "h-10 w-10 text-white") }}
                  </div>
                </div>
                <h3 class="mb-3 text-center font-heading text-xl font-bold {{ item.text_color }} sm:text-2xl">{{ item.label }}</h3>
                <p class="text-center font-body text-sm leading-relaxed text-brand-ink-700 sm:text-base">{{ item.description }}</p>
              </div>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="relative overflow-hidden bg-gradient-subtle py-16 sm:py-20" data-home-section="allies">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute left-10 top-10 h-32 w-32 rounded-full bg-brand-teal-500/5 blur-3xl animate-pulse"></div>
    <div class="absolute bottom-10 right-10 h-40 w-40 rounded-full bg-brand-mint-200/20 blur-3xl animate-pulse delay-1000"></div>
  </div>

  <div class="relative container mx-auto mb-8 px-4 text-center sm:px-6 sm:mb-12 lg:px-8">
    <h2 class="mb-3 font-heading text-2xl font-bold text-brand-ink-900 sm:mb-4 sm:text-3xl md:text-4xl lg:text-5xl">{{ allies.title }}</h2>
    <p class="mx-auto max-w-2xl font-body text-sm text-brand-olive-500 sm:text-base md:text-lg">{{ allies.subtitle }}</p>
  </div>

  <div class="relative flex gap-1 overflow-x-hidden whitespace-nowrap py-8 sm:gap-2" data-ally-scroll>
    {% for ally in allies.items %}
      <div class="inline-flex h-28 w-40 flex-shrink-0 items-center justify-center p-6 transition-smooth hover:scale-110 group sm:h-32 sm:w-48 sm:p-8 md:h-36 md:w-56">
        <img src="{{ ally.logo }}" alt="{{ ally.name }}" class="max-h-full max-w-full object-contain brightness-0 opacity-70 transition-all duration-500 group-hover:opacity-100 group-hover:brightness-100" loading="lazy" />
      </div>
    {% endfor %}
    {% for ally in allies.items %}
      <div class="inline-flex h-28 w-40 flex-shrink-0 items-center justify-center p-6 transition-smooth hover:scale-110 group sm:h-32 sm:w-48 sm:p-8 md:h-36 md:w-56">
        <img src="{{ ally.logo }}" alt="{{ ally.name }}" class="max-h-full max-w-full object-contain brightness-0 opacity-70 transition-all duration-500 group-hover:opacity-100 group-hover:brightness-100" loading="lazy" />
      </div>
    {% endfor %}
  </div>
</section>
