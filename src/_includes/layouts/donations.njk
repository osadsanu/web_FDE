---
layout: layouts/base.njk
---
{% import "components/ui.njk" as ui %}

<div class="min-h-screen bg-gradient-subtle">
  <main class="relative pb-20 pt-28 sm:pt-32">
    <section class="relative mx-4 mb-12 overflow-hidden rounded-2xl shadow-card sm:mx-6 lg:mx-12">
      <img src="{{ hero_image }}" alt="{{ hero_image_alt }}" class="h-64 w-full object-cover sm:h-80 md:h-96" />
      <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-brand-ink-900/90 via-brand-teal-500/80 to-brand-ink-800/90 p-4">
        <div class="max-w-4xl text-center">
          <div class="mb-6 flex justify-center">
            <div class="rounded-full bg-white/10 p-4 backdrop-blur-sm">
              {{ ui.icon(hero_icon, "h-12 w-12 text-brand-mint-200") }}
            </div>
          </div>
          <h1 class="mb-4 font-heading text-4xl font-bold text-white sm:text-5xl lg:text-6xl">{{ hero_title }}</h1>
          <p class="font-body text-lg leading-relaxed text-white/85 sm:text-xl">{{ hero_subtitle }}</p>
        </div>
      </div>
    </section>

    <div class="container mx-auto px-4 sm:px-6">
      <section class="grid gap-8 lg:grid-cols-2">
        {% for tier in tiers %}
          <article class="group icon-hover-card rounded-3xl border border-brand-teal-500/10 bg-white p-8 shadow-card">
            <div class="icon-hover-glow bg-brand-teal-500/10"></div>
            <div class="icon-hover-shell mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-teal-500 to-brand-ink-800 shadow-soft">
              {{ ui.icon(tier.icon, "h-8 w-8 text-white") }}
            </div>
            <h2 class="mb-4 font-heading text-3xl font-bold text-brand-ink-900">{{ tier.title }}</h2>
            <div class="mb-5 flex items-end gap-2">
              <span class="font-heading text-5xl font-black text-brand-teal-600">{{ tier.amount }}</span>
              <span class="pb-2 font-body text-base text-brand-ink-700">{{ tier.period }}</span>
            </div>
            <p class="mb-6 font-body text-base leading-relaxed text-brand-ink-700">{{ tier.description }}</p>
            <ul class="space-y-3">
              {% for benefit in tier.benefits %}
                <li class="inline-flex items-center gap-3 font-body text-sm text-brand-ink-800">
                  <span class="h-2 w-2 rounded-full bg-brand-teal-500"></span>
                  {{ benefit }}
                </li>
              {% endfor %}
            </ul>
          </article>
        {% endfor %}
      </section>

      <section class="mt-16 sm:mt-20">
        <div class="mb-8 text-center">
          <h2 class="mb-4 font-heading text-3xl font-bold text-brand-ink-900 sm:text-4xl">{{ payment_title }}</h2>
          <p class="font-body text-base text-brand-ink-700 sm:text-lg">{{ payment_subtitle }}</p>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          {% for method in payment_methods %}
            <a href="{{ method.url }}" target="_blank" rel="noopener noreferrer" class="rounded-3xl border border-brand-teal-500/10 bg-white p-8 shadow-card transition-smooth hover:-translate-y-1 hover:shadow-cta">
              <div class="mb-4 flex items-center justify-between">
                <h3 class="font-heading text-3xl font-bold text-brand-ink-900">{{ method.name }}</h3>
                {% if method.recommended %}
                  <span class="rounded-full bg-brand-mint-200/40 px-3 py-1 font-body text-xs font-semibold text-brand-ink-800">Recomendado</span>
                {% endif %}
              </div>
              <p class="font-body text-base text-brand-ink-700">{{ method.description }}</p>
            </a>
          {% endfor %}
        </div>
      </section>

      <section class="mt-16 grid gap-6 md:grid-cols-3 sm:mt-20">
        {% for stat in impact_stats %}
          <article class="rounded-3xl bg-gradient-to-br from-brand-ink-900 via-brand-teal-700 to-brand-ink-800 p-8 text-center shadow-cta">
            <p class="stat-card-number mb-3 font-heading text-5xl font-black text-brand-mint-200">{{ stat.number }}</p>
            <p class="font-body text-lg font-semibold text-white">{{ stat.label }}</p>
            <p class="mt-2 font-body text-sm text-white/75">{{ stat.description }}</p>
          </article>
        {% endfor %}
      </section>

      <section class="mt-16 sm:mt-20">
        <div class="overflow-hidden rounded-[2rem] bg-white p-8 text-center shadow-card sm:p-14">
          <h2 class="mb-5 font-heading text-3xl font-bold text-brand-ink-900 sm:text-4xl">{{ cta.title }}</h2>
          <p class="mx-auto mb-8 max-w-3xl font-body text-lg leading-relaxed text-brand-ink-700">{{ cta.text }}</p>
          <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
            {{ ui.button(cta.primary.href, cta.primary.label, "primary", cta.primary.external) }}
            {{ ui.button(cta.secondary.href, cta.secondary.label, "secondary", false) }}
          </div>
        </div>
      </section>
    </div>
  </main>
</div>
