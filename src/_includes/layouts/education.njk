---
layout: layouts/base.njk
---
{% import "components/ui.njk" as ui %}

<div class="min-h-screen bg-gradient-subtle">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute left-10 top-20 h-32 w-32 rounded-full bg-brand-teal-500/5 blur-3xl animate-pulse"></div>
    <div class="absolute bottom-20 right-10 h-40 w-40 rounded-full bg-brand-mint-200/20 blur-3xl animate-pulse delay-1000"></div>
    <div class="absolute left-1/4 top-1/2 h-24 w-24 rounded-full bg-brand-olive-500/5 blur-2xl animate-pulse delay-500"></div>
  </div>

  <main class="relative pb-20 pt-28 sm:pt-32">
    <section class="mx-4 mb-12 overflow-hidden rounded-2xl shadow-card sm:mx-6 lg:mx-12">
      <a href="{{ featured_banner.href }}" target="_blank" rel="noopener noreferrer" class="block">
        <img src="{{ featured_banner.image }}" alt="{{ featured_banner.alt }}" class="h-auto w-full object-cover transition-smooth hover:scale-[1.02]" />
      </a>
    </section>

    <div class="container mx-auto px-4 sm:px-6">
      <div class="mx-auto mb-12 max-w-4xl text-center sm:mb-16">
        <div class="mb-6 flex justify-center">
          <div class="rounded-full bg-gradient-to-br from-brand-teal-500 to-brand-ink-800 p-4 shadow-soft">
            {{ ui.icon(hero_icon, "h-12 w-12 text-white") }}
          </div>
        </div>
        <h1 class="mb-4 font-heading text-4xl font-bold text-brand-ink-900 sm:text-5xl lg:text-6xl">{{ hero_title }}</h1>
        <p class="font-body text-lg leading-relaxed text-brand-ink-700 sm:text-xl">{{ hero_subtitle }}</p>
      </div>

      <div class="grid gap-8 lg:grid-cols-2 xl:grid-cols-3">
        {% for workshop in workshops %}
          <article class="overflow-hidden rounded-3xl border border-brand-teal-500/10 bg-white shadow-card transition-smooth hover:-translate-y-1 hover:shadow-cta">
            <img src="{{ workshop.image }}" alt="{{ workshop.title }}" class="h-56 w-full object-cover" />
            <div class="p-6">
              <div class="mb-4 flex flex-wrap gap-3 text-xs font-semibold">
                <span class="rounded-full bg-brand-teal-500/10 px-3 py-1 text-brand-teal-600">{{ workshop.duration }}</span>
                <span class="rounded-full bg-brand-mint-200/40 px-3 py-1 text-brand-ink-800">{{ workshop.audience }}</span>
              </div>
              <h2 class="mb-4 font-heading text-2xl font-bold text-brand-ink-900">{{ workshop.title }}</h2>
              <p class="mb-6 font-body text-base leading-relaxed text-brand-ink-700">{{ workshop.description }}</p>
              <ul class="space-y-2">
                {% for highlight in workshop.highlights %}
                  <li class="inline-flex items-center gap-2 font-body text-sm text-brand-ink-700">
                    <span class="h-2 w-2 rounded-full bg-brand-teal-500"></span>
                    {{ highlight }}
                  </li>
                {% endfor %}
              </ul>
            </div>
          </article>
        {% endfor %}
      </div>

      <section class="mt-16 sm:mt-20">
        <div class="mb-8 text-center">
          <h2 class="mb-4 font-heading text-3xl font-bold text-brand-ink-900 sm:text-4xl">{{ faq_title }}</h2>
          <p class="font-body text-base text-brand-ink-700 sm:text-lg">{{ faq_subtitle }}</p>
        </div>

        <div class="mx-auto grid max-w-4xl gap-4">
          {% for item in faqs %}
            <details class="rounded-3xl border border-brand-teal-500/10 bg-white p-6 shadow-soft">
              <summary class="cursor-pointer list-none font-heading text-xl font-bold text-brand-ink-900">{{ item.question }}</summary>
              <p class="mt-4 font-body text-base leading-relaxed text-brand-ink-700">{{ item.answer }}</p>
            </details>
          {% endfor %}
        </div>
      </section>

      <section class="mt-16 sm:mt-20">
        <div class="overflow-hidden rounded-[2rem] bg-gradient-to-br from-brand-ink-900 via-brand-teal-700 to-brand-ink-800 p-10 text-center shadow-cta sm:p-14">
          <h2 class="mb-5 font-heading text-3xl font-bold text-white sm:text-4xl">{{ cta.title }}</h2>
          <p class="mx-auto mb-8 max-w-3xl font-body text-lg leading-relaxed text-white/85">{{ cta.text }}</p>
          {{ ui.button(cta.href, cta.label, "ghost", false) }}
        </div>
      </section>
    </div>
  </main>
</div>
