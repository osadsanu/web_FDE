---
layout: layouts/base.njk
---
{% import "components/ui.njk" as ui %}

{% if theme == "mint" %}
  {% set hero_border = "border-brand-mint-200/40" %}
  {% set hero_badge_bg = "bg-brand-mint-200/60" %}
  {% set hero_badge_text = "text-brand-ink-800" %}
{% elif theme == "olive" %}
  {% set hero_border = "border-brand-olive-500/30" %}
  {% set hero_badge_bg = "bg-brand-olive-500/20" %}
  {% set hero_badge_text = "text-brand-olive-500" %}
{% else %}
  {% set hero_border = "border-brand-teal-500/30" %}
  {% set hero_badge_bg = "bg-brand-teal-500/20" %}
  {% set hero_badge_text = "text-brand-teal-500" %}
{% endif %}

<div class="min-h-screen bg-gradient-subtle">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute left-10 top-20 h-32 w-32 rounded-full bg-brand-teal-500/5 blur-3xl animate-pulse"></div>
    <div class="absolute bottom-20 right-10 h-40 w-40 rounded-full bg-brand-mint-200/20 blur-3xl animate-pulse delay-1000"></div>
    <div class="absolute left-1/3 top-1/2 h-28 w-28 rounded-full bg-brand-olive-500/5 blur-2xl animate-pulse delay-500"></div>
  </div>

  <section class="relative pb-10 pt-28 sm:pt-32">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-5xl">
        <a href="/blog/" class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand-mint-200/40 bg-white px-4 py-2 font-body text-sm font-semibold text-brand-ink-800 shadow-soft transition-smooth hover:bg-brand-mint-200/20 hover:text-brand-teal-500 sm:mb-8">
          {{ ui.icon("arrow-left", "h-4 w-4") }}
          <span>Volver al blog</span>
        </a>

        <div class="overflow-hidden rounded-[2rem] border {{ hero_border }} bg-white/90 shadow-card backdrop-blur-sm">
          <div class="grid lg:grid-cols-2">
            <div class="p-8 sm:p-10 lg:p-12">
              <span class="mb-4 inline-flex items-center rounded-full {{ hero_badge_bg }} {{ hero_badge_text }} px-3 py-1 text-xs font-semibold shadow-soft">
                {{ tag }}
              </span>
              <h1 class="mb-4 font-heading text-3xl font-bold leading-heading-1 text-brand-ink-900 sm:text-4xl lg:text-5xl">{{ title }}</h1>
              <p class="mb-6 font-body text-base leading-relaxed text-brand-ink-700 sm:text-lg">{{ excerpt }}</p>

              <div class="flex flex-wrap items-center gap-3 text-xs text-brand-olive-500 sm:gap-4 sm:text-sm">
                <div class="flex items-center gap-1.5">
                  {{ ui.icon("calendar", "h-3.5 w-3.5 sm:h-4 sm:w-4") }}
                  <time datetime="{{ date | isoDate }}" class="font-body">{{ date | readableDateEs }}</time>
                </div>
                <div class="flex items-center gap-1.5">
                  {{ ui.icon("user", "h-3.5 w-3.5 sm:h-4 sm:w-4") }}
                  <span class="font-body">{{ author }}</span>
                </div>
                <div class="flex items-center gap-1.5">
                  {{ ui.icon("book-open", "h-3.5 w-3.5 sm:h-4 sm:w-4") }}
                  <span class="font-body">{{ readTime }}</span>
                </div>
              </div>
            </div>

            <div class="relative min-h-[18rem] overflow-hidden lg:min-h-full">
              <img src="{{ image }}" alt="{{ title }}" class="absolute inset-0 h-full w-full object-cover" />
              <div class="absolute inset-0 bg-gradient-to-tr from-brand-ink-900/20 via-transparent to-brand-teal-500/20"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative pb-16 sm:pb-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <article class="article-prose mx-auto max-w-4xl rounded-[2rem] border border-brand-mint-200/40 bg-white p-8 shadow-card sm:p-10 lg:p-12">
        {{ content | safe }}
      </article>
    </div>
  </section>

  {% set relatedCount = 0 %}
  {% for entry in collections.blogPosts %}
    {% if entry.url != page.url %}
      {% set relatedCount = relatedCount + 1 %}
    {% endif %}
  {% endfor %}

  {% if relatedCount > 0 %}
    <section class="relative pb-20">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <div class="mb-8 text-center sm:mb-10">
            <h2 class="mb-3 font-heading text-2xl font-bold text-brand-ink-900 sm:text-3xl">Más del Blog</h2>
            <p class="font-body text-sm text-brand-olive-500 sm:text-base">Sigue explorando recursos y artículos relacionados.</p>
          </div>

          <div class="grid grid-cols-1 gap-6 sm:gap-8 md:grid-cols-2 lg:grid-cols-3">
            {% set shown = 0 %}
            {% for entry in collections.blogPosts %}
              {% if entry.url != page.url and shown < 3 %}
                {% set post = entry.data %}
                {% if post.theme == "mint" %}
                  {% set card_border = "border-brand-mint-200/40" %}
                  {% set card_bg = "bg-brand-mint-200/20" %}
                  {% set badge_bg = "bg-brand-mint-200/60" %}
                  {% set badge_text = "text-brand-ink-800" %}
                {% elif post.theme == "olive" %}
                  {% set card_border = "border-brand-olive-500/30" %}
                  {% set card_bg = "bg-brand-olive-500/10" %}
                  {% set badge_bg = "bg-brand-olive-500/20" %}
                  {% set badge_text = "text-brand-olive-500" %}
                {% else %}
                  {% set card_border = "border-brand-teal-500/30" %}
                  {% set card_bg = "bg-brand-teal-500/10" %}
                  {% set badge_bg = "bg-brand-teal-500/20" %}
                  {% set badge_text = "text-brand-teal-500" %}
                {% endif %}
                <article class="group flex h-full flex-col overflow-hidden rounded-lg border {{ card_border }} {{ card_bg }} shadow-sm transition-smooth hover:scale-105 hover:shadow-card">
                  <a href="{{ entry.url }}" class="relative overflow-hidden">
                    <img src="{{ post.image }}" alt="{{ post.title }}" class="h-48 w-full object-cover transition-smooth group-hover:scale-110 sm:h-56" loading="lazy" />
                    <div class="absolute right-3 top-3">
                      <span class="inline-flex items-center rounded-full {{ badge_bg }} {{ badge_text }} px-2.5 py-0.5 text-xs font-semibold shadow-soft">
                        {{ post.tag }}
                      </span>
                    </div>
                  </a>
                  <div class="flex flex-1 flex-col p-5 sm:p-6">
                    <div class="mb-3 flex flex-wrap items-center gap-3 text-xs text-brand-olive-500 sm:mb-4 sm:gap-4 sm:text-sm">
                      <div class="flex items-center gap-1.5">
                        {{ ui.icon("calendar", "h-3.5 w-3.5 sm:h-4 sm:w-4") }}
                        <time datetime="{{ post.date | isoDate }}" class="font-body">{{ post.date | readableDateEs }}</time>
                      </div>
                      <div class="flex items-center gap-1.5">
                        {{ ui.icon("book-open", "h-3.5 w-3.5 sm:h-4 sm:w-4") }}
                        <span class="font-body">{{ post.readTime }}</span>
                      </div>
                    </div>
                    <h3 class="mb-2 font-heading text-lg font-bold leading-heading-3 text-brand-ink-900 transition-smooth group-hover:text-brand-teal-500 sm:mb-3 sm:text-xl">
                      <a href="{{ entry.url }}">{{ post.title }}</a>
                    </h3>
                    <p class="mb-4 flex-1 font-body text-sm leading-relaxed text-brand-ink-800 sm:text-base">{{ post.excerpt }}</p>
                    <a href="{{ entry.url }}" class="group/btn inline-flex items-center justify-between gap-2 font-body text-sm font-semibold text-brand-teal-500 transition-smooth hover:bg-brand-teal-500/10 hover:text-brand-ink-800 sm:text-base">
                      <span>Leer más</span>
                      {{ ui.icon("arrow-right", "h-4 w-4 transition-smooth group-hover/btn:translate-x-1") }}
                    </a>
                  </div>
                </article>
                {% set shown = shown + 1 %}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </section>
  {% endif %}
</div>
