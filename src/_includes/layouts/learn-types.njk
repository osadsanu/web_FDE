---
layout: layouts/base.njk
---
{% import "components/ui.njk" as ui %}

<div class="min-h-screen bg-gradient-subtle">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute left-10 top-20 h-32 w-32 rounded-full bg-brand-teal-500/5 blur-3xl animate-pulse"></div>
    <div class="absolute bottom-20 right-10 h-40 w-40 rounded-full bg-brand-mint-200/20 blur-3xl animate-pulse delay-1000"></div>
  </div>

  <main class="relative pb-20 pt-28 sm:pt-32">
    <div class="container mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mb-10 text-center sm:mb-16">
        <div class="mb-6 flex justify-center">
          <div class="rounded-full bg-gradient-to-br from-brand-olive-500 to-brand-ink-800 p-4 shadow-cta">
            {{ ui.icon(hero_icon, "h-12 w-12 text-white") }}
          </div>
        </div>
        <h1 class="mb-4 font-heading text-4xl font-bold text-brand-ink-900 sm:text-5xl lg:text-6xl">{{ hero_title }}</h1>
        <p class="mx-auto mb-6 max-w-4xl font-body text-lg leading-relaxed text-brand-ink-700 sm:text-xl">{{ hero_subtitle }}</p>
        <span class="rounded-full bg-brand-mint-200/35 px-5 py-2 font-body text-sm font-semibold text-brand-ink-800 shadow-soft">{{ hero_badge }}</span>
      </div>

      <div class="space-y-8">
        {% for type in types %}
          <article class="overflow-hidden rounded-[2rem] border {{ type.border_class }} bg-white shadow-card">
            <div class="grid gap-0 lg:grid-cols-[320px_minmax(0,1fr)]">
              <img src="{{ type.image }}" alt="{{ type.title }}" class="h-full min-h-[240px] w-full object-cover" />
              <div class="p-8 sm:p-10">
                <h2 class="mb-4 font-heading text-3xl font-bold {{ type.text_class }}">{{ type.title }}</h2>
                <p class="mb-4 font-body text-base leading-relaxed text-brand-ink-700">{{ type.description }}</p>
                {% if type.details %}
                  <p class="mb-6 font-body text-base leading-relaxed text-brand-ink-700">{{ type.details }}</p>
                {% endif %}

                {% if type.vertientes %}
                  <div class="grid gap-4 md:grid-cols-3">
                    {% for item in type.vertientes %}
                      <div class="rounded-2xl {{ type.light_class }} p-4">
                        <h3 class="mb-2 font-heading text-lg font-bold text-brand-ink-900">{{ item.nombre }}</h3>
                        <p class="font-body text-sm leading-relaxed text-brand-ink-700">{{ item.stat }}</p>
                      </div>
                    {% endfor %}
                  </div>
                {% endif %}

                {% if type.elementos %}
                  <div class="grid gap-4 md:grid-cols-3">
                    {% for item in type.elementos %}
                      <div class="rounded-2xl {{ type.light_class }} p-4">
                        <h3 class="mb-2 font-heading text-lg font-bold text-brand-ink-900">{{ item.titulo }}</h3>
                        <p class="font-body text-sm leading-relaxed text-brand-ink-700">{{ item.desc }}</p>
                      </div>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            </div>
          </article>
        {% endfor %}
      </div>

      <section class="mt-16 grid gap-6 md:grid-cols-2 sm:mt-20">
        {% for link in links %}
          <a href="{{ link.href }}" class="rounded-3xl border border-brand-teal-500/10 bg-white p-8 shadow-soft transition-smooth hover:-translate-y-1 hover:shadow-card">
            <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[0.24em] text-brand-teal-600">{{ link.eyebrow }}</p>
            <h3 class="font-heading text-3xl font-bold text-brand-ink-900">{{ link.title }}</h3>
          </a>
        {% endfor %}
      </section>
    </div>
  </main>
</div>
