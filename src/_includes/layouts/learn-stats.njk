---
layout: layouts/base.njk
---
{% import "components/ui.njk" as ui %}

<div class="min-h-screen bg-gradient-subtle">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute left-10 top-20 h-32 w-32 rounded-full bg-brand-teal-500/5 blur-3xl animate-pulse"></div>
    <div class="absolute bottom-20 right-10 h-40 w-40 rounded-full bg-brand-mint-200/20 blur-3xl animate-pulse delay-1000"></div>
  </div>

  <main class="relative pb-20 pt-28 sm:pt-32">
    <div class="container mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mb-10 text-center sm:mb-16">
        <div class="mb-6 flex justify-center">
          <div class="rounded-full bg-gradient-to-br from-brand-teal-500 to-brand-ink-800 p-4 shadow-cta">
            {{ ui.icon(hero_icon, "h-12 w-12 text-white") }}
          </div>
        </div>
        <h1 class="mb-4 font-heading text-4xl font-bold text-brand-ink-900 sm:text-5xl lg:text-6xl">{{ hero_title }}</h1>
        <p class="mx-auto mb-6 max-w-4xl font-body text-lg leading-relaxed text-brand-ink-700 sm:text-xl">{{ hero_subtitle }}</p>
        <span class="rounded-full bg-brand-mint-200/35 px-5 py-2 font-body text-sm font-semibold text-brand-ink-800 shadow-soft">{{ sources_badge }}</span>
      </div>

      <section class="grid gap-6 md:grid-cols-3">
        {% for item in primary_stats %}
          <article class="rounded-3xl bg-gradient-to-br from-brand-ink-900 via-brand-teal-700 to-brand-ink-800 p-8 text-center shadow-cta">
            <p class="stat-card-number mb-3 font-heading text-5xl font-black text-brand-mint-200">{{ item.number }}</p>
            <p class="font-body text-lg font-semibold text-white">{{ item.label }}</p>
            <p class="mt-2 font-body text-sm text-white/75">{{ item.description }}</p>
          </article>
        {% endfor %}
      </section>

      <section class="mt-12 grid gap-6 md:grid-cols-3">
        {% for item in secondary_stats %}
          <article class="rounded-3xl border border-brand-teal-500/10 bg-white p-8 shadow-card">
            <p class="stat-card-number mb-3 font-heading text-5xl font-black text-brand-teal-600">{{ item.number }}</p>
            <h2 class="mb-3 font-heading text-2xl font-bold text-brand-ink-900">{{ item.label }}</h2>
            <p class="mb-3 font-body text-base leading-relaxed text-brand-ink-700">{{ item.description }}</p>
            <p class="font-body text-sm font-semibold text-brand-olive-600">{{ item.source }}</p>
          </article>
        {% endfor %}
      </section>

      <section class="mt-16 sm:mt-20">
        <div class="overflow-hidden rounded-[2rem] bg-white p-8 text-center shadow-card sm:p-14">
          <h2 class="mb-5 font-heading text-3xl font-bold text-brand-ink-900 sm:text-4xl">{{ cta.title }}</h2>
          <p class="mx-auto mb-8 max-w-3xl font-body text-lg leading-relaxed text-brand-ink-700">{{ cta.text }}</p>
          <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
            {{ ui.button(cta.primary.href, cta.primary.label, "primary", false) }}
            {{ ui.button(cta.secondary.href, cta.secondary.label, "secondary", false) }}
          </div>
        </div>
      </section>
    </div>
  </main>
</div>
