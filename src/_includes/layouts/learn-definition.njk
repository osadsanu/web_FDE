---
layout: layouts/base.njk
---
{% import "components/ui.njk" as ui %}

<div class="min-h-screen bg-white">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-mint-200/20 via-white to-brand-teal-500/10"></div>
    <div class="absolute right-10 top-20 h-72 w-72 rounded-full bg-brand-teal-500/10 blur-3xl animate-float"></div>
    <div class="absolute bottom-20 left-10 h-80 w-80 rounded-full bg-brand-mint-200/30 blur-3xl animate-float delay-1000"></div>
  </div>

  <main class="relative pb-20 pt-28 sm:pt-32">
    <div class="container mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center sm:mb-16">
        <div class="mb-6 inline-flex items-center justify-center rounded-full border border-brand-teal-500/20 bg-white/80 px-6 py-3 shadow-soft">
          <span class="font-body text-sm font-bold uppercase tracking-[0.28em] text-brand-teal-600">{{ eyebrow }}</span>
        </div>
        <div class="mb-6 flex justify-center">
          <div class="rounded-3xl bg-gradient-to-br from-brand-teal-500 to-brand-ink-800 p-4 shadow-cta">
            {{ ui.icon(hero_icon, "h-12 w-12 text-white sm:h-16 sm:w-16") }}
          </div>
        </div>
        <h1 class="mb-6 font-heading text-4xl font-bold text-brand-ink-900 sm:text-5xl lg:text-6xl">{{ hero_title }}</h1>
        <p class="mx-auto mb-8 max-w-3xl font-body text-lg leading-relaxed text-brand-ink-700 sm:text-xl">{{ hero_subtitle }}</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          {% for badge in badges %}
            <span class="rounded-full border border-brand-teal-500/15 bg-white/85 px-4 py-2 font-body text-sm font-semibold text-brand-ink-800 shadow-soft">{{ badge }}</span>
          {% endfor %}
        </div>
      </div>

      <section class="mb-16 overflow-hidden rounded-[2rem] bg-gradient-to-br from-brand-teal-500 via-brand-teal-600 to-brand-ink-800 p-8 shadow-cta sm:p-12 lg:p-16">
        <div class="text-center">
          <div class="mb-6 inline-block rounded-full bg-white/10 px-5 py-2 backdrop-blur-sm">
            <p class="font-body text-sm font-semibold uppercase tracking-wider text-white/90">Definición Oficial</p>
          </div>
          <h2 class="mb-6 font-heading text-3xl font-bold text-white sm:text-4xl">{{ definition_title }}</h2>
          <p class="mx-auto max-w-4xl font-body text-lg leading-relaxed text-white/95 sm:text-xl">{{ definition_text }}</p>
        </div>
      </section>

      <section class="mb-16 sm:mb-20">
        <div class="mb-10 text-center">
          <h2 class="mb-4 font-heading text-3xl font-bold text-brand-ink-900 sm:text-4xl">{{ elements_title }}</h2>
          <p class="font-body text-base text-brand-ink-700 sm:text-lg">{{ elements_subtitle }}</p>
        </div>

        <div class="grid gap-8 lg:grid-cols-3">
          {% for item in elements %}
            <article class="group icon-hover-card rounded-3xl border {{ item.border_class }} {{ item.bg_class }} p-8 shadow-card">
              <div class="icon-hover-glow bg-brand-teal-500/10"></div>
              <div class="icon-hover-shell mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br {{ item.gradient }} shadow-soft">
                {{ ui.icon(item.icon, "h-8 w-8 text-white") }}
              </div>
              <p class="mb-2 font-body text-sm font-semibold uppercase tracking-[0.24em] {{ item.text_class }}">{{ item.subtitle }}</p>
              <h3 class="mb-4 font-heading text-3xl font-bold {{ item.text_class }}">{{ item.title }}</h3>
              <ul class="space-y-3">
                {% for entry in item.items %}
                  <li class="inline-flex items-center gap-3 font-body text-sm text-brand-ink-800">
                    <span class="h-2 w-2 rounded-full bg-brand-teal-500"></span>
                    {{ entry }}
                  </li>
                {% endfor %}
              </ul>
            </article>
          {% endfor %}
        </div>
      </section>

      <section class="grid gap-6 md:grid-cols-2">
        {% for link in links %}
          <a href="{{ link.href }}" class="rounded-3xl border border-brand-teal-500/10 bg-white p-8 shadow-soft transition-smooth hover:-translate-y-1 hover:shadow-card">
            <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[0.24em] text-brand-teal-600">{{ link.eyebrow }}</p>
            <h3 class="font-heading text-3xl font-bold text-brand-ink-900">{{ link.title }}</h3>
          </a>
        {% endfor %}
      </section>
    </div>
  </main>
</div>
