{% macro icon(name, className="h-6 w-6") %}
  {% if name == "heart" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M12 21s-6.7-4.4-9-8.3C1.1 9.3 2 5.5 5.7 4.2c2.2-.8 4.4.1 6.3 2.3 1.9-2.2 4.1-3.1 6.3-2.3 3.7 1.3 4.6 5.1 2.7 8.5-2.3 3.9-9 8.3-9 8.3Z"/></svg>
  {% elif name == "house" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
  {% elif name == "shield" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M12 3l7 3v6c0 4.5-2.8 7.9-7 9-4.2-1.1-7-4.5-7-9V6l7-3Z"/><path d="m9.5 12 1.7 1.7 3.3-3.4"/></svg>
  {% elif name == "users" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="9.5" cy="7" r="3"/><path d="M20 21v-2a4 4 0 0 0-3-3.9"/><path d="M15.5 4.3a3 3 0 0 1 0 5.4"/></svg>
  {% elif name == "megaphone" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M3 11v2a2 2 0 0 0 2 2h2l3 4h2l-1.5-4H13l7 3V6l-7 3H5a2 2 0 0 0-2 2Z"/></svg>
  {% elif name == "globe" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a15 15 0 0 1 0 18"/><path d="M12 3a15 15 0 0 0 0 18"/></svg>
  {% elif name == "hand" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M8 11V5a1 1 0 1 1 2 0v5"/><path d="M12 11V4a1 1 0 1 1 2 0v7"/><path d="M16 11V6a1 1 0 1 1 2 0v8c0 3.3-2.7 6-6 6H9.7a5 5 0 0 1-3.7-1.6L3 15.2a1.4 1.4 0 0 1 2-2l2 2V8a1 1 0 1 1 2 0v3"/></svg>
  {% elif name == "book" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z"/></svg>
  {% elif name == "chart" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M3 3v18h18"/><path d="m7 14 4-4 3 3 5-7"/></svg>
  {% elif name == "school" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="m2 10 10-6 10 6-10 6-10-6Z"/><path d="M6 12v5c0 1.7 2.7 3 6 3s6-1.3 6-3v-5"/><path d="M22 10v6"/></svg>
  {% elif name == "file" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M8 13h8"/><path d="M8 17h5"/></svg>
  {% elif name == "volunteer" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><circle cx="12" cy="7" r="3"/><path d="M5 21a7 7 0 0 1 14 0"/><path d="M19 8h3"/><path d="M20.5 6.5v3"/></svg>
  {% elif name == "donate" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M12 1v22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7H14.5a3.5 3.5 0 0 1 0 7H6"/></svg>
  {% elif name == "warning" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M12 3 2 21h20L12 3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
  {% elif name == "facebook" %}
    <svg viewBox="0 0 24 24" fill="currentColor" class="{{ className }}"><path d="M13.5 21v-7h2.4l.4-3h-2.8V9.2c0-.9.3-1.5 1.6-1.5H16V5.1c-.4-.1-1.3-.1-2.2-.1-2.2 0-3.8 1.3-3.8 3.9V11H7.5v3H10v7h3.5Z"/></svg>
  {% elif name == "x" %}
    <svg viewBox="0 0 24 24" fill="currentColor" class="{{ className }}"><path d="M18.9 3H21l-4.6 5.3L22 21h-4.6l-3.6-4.8L9.6 21H7.5l4.9-5.7L2 3h4.7l3.3 4.5L13.9 3Zm-1.6 16h1.3L6 4.9H4.6Z"/></svg>
  {% elif name == "instagram" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1"/></svg>
  {% elif name == "mail" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/></svg>
  {% elif name == "phone" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M22 16.9v3a2 2 0 0 1-2.2 2A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7l.4 2.7a2 2 0 0 1-.6 1.8l-2 2a16 16 0 0 0 6.9 6.9l2-2a2 2 0 0 1 1.8-.6l2.7.4A2 2 0 0 1 22 16.9Z"/></svg>
  {% elif name == "map-pin" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M12 21s-6-5.3-6-10a6 6 0 1 1 12 0c0 4.7-6 10-6 10Z"/><circle cx="12" cy="11" r="2"/></svg>
  {% elif name == "search" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
  {% elif name == "calendar" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M8 2v4"/><path d="M16 2v4"/><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18"/></svg>
  {% elif name == "user" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
  {% elif name == "book-open" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3Z"/></svg>
  {% elif name == "arrow-left" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M19 12H5"/><path d="m11 5-7 7 7 7"/></svg>
  {% elif name == "arrow-right" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
  {% elif name == "chevron-down" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="m6 9 6 6 6-6"/></svg>
  {% elif name == "target" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5"/></svg>
  {% elif name == "eye" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M2.4 12s3.6-6 9.6-6 9.6 6 9.6 6-3.6 6-9.6 6-9.6-6-9.6-6Z"/><circle cx="12" cy="12" r="3"/></svg>
  {% elif name == "menu" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/></svg>
  {% elif name == "close" %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
  {% else %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ className }}"><circle cx="12" cy="12" r="9"/></svg>
  {% endif %}
{% endmacro %}

{% macro button(href, label, variant="primary", external=false, className="") %}
  {% set baseClasses = "inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 font-body text-sm font-semibold transition-smooth" %}
  {% if variant == "secondary" %}
    {% set palette = "border border-brand-teal-500/25 bg-white/90 text-brand-ink-900 shadow-soft hover:bg-white" %}
  {% elif variant == "ghost" %}
    {% set palette = "border border-white/20 bg-white/10 text-white backdrop-blur-sm hover:bg-white/15" %}
  {% else %}
    {% set palette = "bg-gradient-to-r from-brand-teal-500 to-brand-ink-800 text-white shadow-cta hover:opacity-95" %}
  {% endif %}
  <a
    href="{{ href }}"
    class="{{ baseClasses }} {{ palette }} {{ className }}"
    {% if external %}target="_blank" rel="noopener noreferrer"{% endif %}
  >
    <span>{{ label }}</span>
    {{ icon("arrow-right", "h-4 w-4") }}
  </a>
{% endmacro %}
